<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>iFipe - Painel Lojista</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        body { background-color: #000000; color: #ffffff; font-family: -apple-system, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        .apple-card { background: #1c1c1e; border: 1px solid #38383a; border-radius: 20px; padding: 2.5rem; width: 100%; max-width: 420px; box-shadow: 0 20px 40px rgba(0,0,0,0.6); }
        .apple-input { background: #2c2c2e; border: 1px solid #38383a; border-radius: 12px; padding: 14px; width: 100%; color: white; outline: none; margin-bottom: 1rem; transition: 0.2s; font-size: 14px; }
        .apple-input:focus { border-color: #0071e3; }
        .apple-button { background: #ffffff; color: #000000; font-weight: 800; border-radius: 50px; padding: 16px; width: 100%; cursor: pointer; transition: 0.3s; margin-top: 1rem; text-transform: uppercase; letter-spacing: 1px; }
        .apple-button:hover { background: #0071e3; color: white; transform: scale(1.02); }
        label { display: block; text-transform: uppercase; font-size: 10px; color: #86868b; margin-bottom: 6px; font-weight: 900; letter-spacing: 0.1em; margin-top: 1rem; }
        .hidden { display: none; }
    </style>
</head>
<body>

    <div id="loginSection" class="apple-card text-center">
        <h1 class="text-4xl font-black italic mb-2 tracking-tighter">iFipe</h1>
        <p class="text-[10px] font-bold uppercase text-gray-500 mb-10 tracking-[0.3em]">Gestão Lojista Oficial</p>
        
        <div class="text-left">
            <label>Identificação (Nome ou ID)</label>
            <input type="text" id="loginId" class="apple-input" placeholder="Ex: JOGADOR">
            
            <label>Senha de Acesso</label>
            <input type="password" id="loginPass" class="apple-input" placeholder="••••••••">
        </div>
        
        <button onclick="fazerLogin()" class="apple-button">Acessar Sistema</button>
        <p id="loginError" class="text-red-500 text-[10px] mt-4 font-bold uppercase tracking-widest"></p>
    </div>

    <div id="formSection" class="apple-card hidden">
        <div class="flex justify-between items-center mb-8">
            <span id="welcomeMsg" class="font-black text-blue-500 uppercase italic text-xs tracking-widest"></span>
            <button onclick="location.reload()" class="text-[9px] text-gray-500 underline font-black uppercase">Sair</button>
        </div>

        <form id="priceForm">
            <label>Modelo do Aparelho</label>
            <select id="produto_id" class="apple-input" required>
                <option value="">Carregando modelos...</option>
            </select>

            <label>Grade Disponível</label>
            <select id="variacao_id" class="apple-input" required disabled>
                <option value="">Aguardando modelo...</option>
            </select>

            <label>Origem / Região</label>
            <select id="regiao_id" class="apple-input" required></select>

            <label>Valor à Vista (R$)</label>
            <input type="number" id="preco" class="apple-input" placeholder="Ex: 7490.00" step="0.01" min="1" required>

            <button type="submit" class="apple-button">Publicar Oferta</button>
        </form>
        <p id="status" class="mt-6 text-center text-[10px] font-black uppercase tracking-widest"></p>
    </div>

    <script>
        // Configuração Supabase
        const _supabase = supabase.createClient('https://zmgosywpwidypxyhxkry.supabase.co', 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InptZ29zeXdwd2lkeXB4eWh4a3J5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE4MTg3MTYsImV4cCI6MjA4NzM5NDcxNn0.qE_JfgeSOF7VzsySjmnnAQkYngGJ_Lc5scOXLrhut-M');
        let fornecedorLogado = null;

        // Login flexível (Aceita Nome ou ID)
        async function fazerLogin() {
            const login = document.getElementById('loginId').value;
            const pass = document.getElementById('loginPass').value;
            const errorEl = document.getElementById('loginError');

            const isNumeric = !isNaN(login) && login.trim() !== "";
            
            const { data, error } = await _supabase
                .from('fornecedores')
                .select('*')
                .or(`id.eq.${isNumeric ? login : -1},nome.eq.${login}`)
                .eq('senha', pass)
                .maybeSingle();

            if (data) {
                fornecedorLogado = data;
                document.getElementById('loginSection').classList.add('hidden');
                document.getElementById('formSection').classList.remove('hidden');
                document.getElementById('welcomeMsg').innerText = "Loja: " + data.nome;
                carregarBases();
            } else {
                errorEl.innerText = "Acesso Negado: Verifique seus dados.";
            }
        }

        // Sincronização com o Banco Master
        async function carregarBases() {
            const { data: m } = await _supabase.from('produtos_mestre').select('id, nome').order('id');
            const { data: r } = await _supabase.from('regioes').select('id, nome, bandeira').order('id');
            const { data: v } = await _supabase.from('variacoes').select('*');
            
            const pS = document.getElementById('produto_id');
            const rS = document.getElementById('regiao_id');
            const vS = document.getElementById('variacao_id');

            pS.innerHTML = '<option value="">Escolha o iPhone</option>' + m.map(i => `<option value="${i.id}">${i.nome}</option>`).join('');
            rS.innerHTML = r.map(i => `<option value="${i.id}">${i.bandeira} ${i.nome}</option>`).join('');
            
            pS.onchange = (e) => {
                const filtradas = v.filter(item => item.produto_id == e.target.value);
                vS.innerHTML = filtradas.map(item => `<option value="${item.id}">${item.capacidade} • ${item.cor}</option>`).join('');
                vS.disabled = filtradas.length === 0;
            };
        }

        // Publicação de Oferta
        document.getElementById('priceForm').onsubmit = async (e) => {
            e.preventDefault();
            const status = document.getElementById('status');
            status.innerText = "Publicando...";
            status.style.color = "white";

            const { error } = await _supabase.from('ofertas').insert([{
                fornecedor_id: fornecedorLogado.id,
                variacao_id: document.getElementById('variacao_id').value,
                regiao_id: document.getElementById('regiao_id').value,
                preco: parseFloat(document.getElementById('preco').value)
            }]);

            if (error) {
                status.innerText = "Falha ao publicar!";
                status.style.color = "#ff3b30";
            } else {
                status.innerText = "Sucesso: Preço no Ranking! 🚀";
                status.style.color = "#32d74b";
                e.target.reset();
            }
        };
    </script>
</body>
</html>
